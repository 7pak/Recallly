<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android 11 (API 30) and below.
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- Back up DataStore preferences (language, persona, onboarding state) -->
    <include domain="file" path="datastore/" />

    <!-- Back up voice notes and custom fields JSON -->
    <include domain="file" path="voice_notes.json" />
    <include domain="file" path="custom_fields.json" />
</full-backup-content>
